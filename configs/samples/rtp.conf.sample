;
; rtp.conf
;
; Constrains Asterisk's RTP port allocator to the range our public
; LoadBalancer Service forwards (UDP 10000-10099). Without this clamp
; Asterisk picks any port in 10000-20000 and most RTP packets get
; dropped at the NLB — symptom is "call connects, no audio one or
; both ways".
;
; Capacity: 100 ports = 50 concurrent calls (each call needs one
; RTP + one RTCP port). To raise the ceiling, widen both this range
; AND the NLB Service's port list together; the two must match.
;
; strictrtp / icesupport / etc. fall through to Asterisk defaults
; (strictrtp=yes since 14, which is correct for a NAT'd deployment).
;

[general]
rtpstart=10000
rtpend=10099

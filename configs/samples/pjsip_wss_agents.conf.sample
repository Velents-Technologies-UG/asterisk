;
; pjsip_wss_agents.conf.sample
;
; PJSIP fragments wiring browser-based agent softphones into Asterisk:
;   - Secure WebSocket transport on port 8089 (TLS termination via http.conf)
;   - Reusable [agent-endpoint-template] / [agent-aor-template] /
;     [agent-auth-template] templates that the agenthub-call-engine
;     provisions per-agent via PJSIP realtime
;
; Required modules:
;     res_pjsip.so, res_pjsip_session.so, res_pjsip_transport_websocket.so
;     res_http_websocket.so, res_srtp.so
;     (for realtime) res_sorcery_realtime.so, res_config_odbc.so, res_odbc.so
;
; Companion files:
;     http_wss.conf.sample           - http.conf TLS bind on 8089
;     sorcery_realtime_agents.conf.sample
;     extconfig_realtime_agents.conf.sample
;     res_odbc_agents.conf.sample
;

;------------------------------------------------------------
; WebSocket-Secure transport (browser softphones)
;------------------------------------------------------------
[transport-wss]
type=transport
protocol=wss
bind=0.0.0.0
; PJSIP only declares the protocol; the actual TLS listener is the
; Asterisk HTTP server bound to 0.0.0.0:8089 (see http_wss.conf.sample).

;------------------------------------------------------------
; Templates: WebRTC + DTLS-SRTP, opus + alaw
;
; context=from-wss-agents-out routes every dial from a registered
; agent's softphone to the [from-wss-agents-out] dialplan in
; extensions_ai_runtime.conf, which hands the call to Stasis so
; the call-engine can apply the tenant's outbound_rules.
;------------------------------------------------------------
[agent-endpoint-template](!)
type=endpoint
transport=transport-wss
context=from-wss-agents-out
disallow=all
allow=opus
allow=alaw
direct_media=no
ice_support=yes
use_avpf=yes
rtcp_mux=yes
media_encryption=dtls
dtls_verify=fingerprint
dtls_setup=actpass
dtls_auto_generate_cert=yes
rtp_symmetric=yes
force_rport=yes
rewrite_contact=yes
webrtc=yes
allow_subscribe=yes
send_pai=yes

[agent-aor-template](!)
type=aor
max_contacts=1
remove_existing=yes
qualify_frequency=60

[agent-auth-template](!)
type=auth
auth_type=userpass

; Agents are provisioned at runtime by agenthub-call-engine, which writes
; ps_endpoints/ps_auths/ps_aors via sorcery using the templates above. No
; static demo agent ships here (it carried a change-me placeholder password).

;------------------------------------------------------------
; Dialplan landing context for WSS agent outbound is
; [from-wss-agents-out] in extensions_ai_runtime.conf.sample. The
; legacy [from-agents] context is now reserved for the queue
; dispatcher's INBOUND ring target (_agent_X. pattern); see
; extensions_ai_runtime.conf.sample.
;------------------------------------------------------------

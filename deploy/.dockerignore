# Build context excludes for `docker build -f deploy/Dockerfile.prod .`
# Keeps the build context lean (the full Asterisk source tree is large
# even before build artefacts).

# Git / CI metadata.
.git
.github
.gitignore
.gitattributes
.gitmodules
.cleancount

# Top-level docs - we have our own README in deploy/.
README-SERIOUSLY.bestpractices.md
README-addons.txt
SECURITY.md
CREDITS
BUGS
COPYING
LICENSE
Zaptel-to-DAHDI.txt

# Editor / OS junk.
.DS_Store
.idea
.vscode
*.swp
*.swo
*~

# Pre-built artefacts from a host-side `make` that would otherwise
# leak into the build stage.
*.o
*.a
*.lo
*.la
*.so
*.so.[0-9]*

# Build state files that should be regenerated by ./bootstrap.sh /
# ./configure inside the container.
config.cache
config.log
config.status
makeopts
menuselect.makeopts
menuselect.makedeps
build.tools

# Tests (large, not needed at runtime).
tests/

# Static HTTP assets / images bundled with upstream Asterisk - we
# don't serve the built-in admin UI from the call-engine deployment.
static-http/
images/

# Documentation generators / output.
doc/

# Sound release tarballs that may exist locally; the Dockerfile
# pulls fresh sounds via menuselect.
*.tar.gz
*.tar.xz
*.zip

# Recursion safety: don't pull deploy/ into deploy/Dockerfile.* contexts.
deploy/Dockerfile.dev
deploy/Dockerfile.prod
deploy/.dockerignore
deploy/README.md
